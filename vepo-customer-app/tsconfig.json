{
	"extends": "expo/tsconfig.base",
	"compilerOptions": {
		"strict": true,
		"jsx": "react-native",
		"moduleResolution": "bundler",
		"allowSyntheticDefaultImports": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"lib": ["es2021", "DOM", "ESNext"],
		"paths": { "@/*": ["./*"] }
	},
	"include": [ "**/*.ts", "**/*.tsx", ".expo/types/**/*.ts", "expo-env.d.ts", "nativewind-env.d.ts", "components/SVGS/LoginSvg.jsx", "constants/icons/icons.js" ]
}