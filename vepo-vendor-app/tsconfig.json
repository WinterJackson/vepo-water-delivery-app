{
	"extends": "expo/tsconfig.base",
	"compilerOptions": {
		"strict": true,
		"jsx": "react-native",
		"moduleResolution": "bundler",
		"module": "esnext",
		"allowSyntheticDefaultImports": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"allowJs": true,
		"lib": ["es2021", "DOM", "ESNext"],
		"paths": { 
			"@/*": ["./*"],
			"@clerk/clerk-expo": ["./node_modules/@clerk/clerk-expo/dist/index.d.ts"]
		}
	},
	"include": [ "**/*.ts", "**/*.tsx", ".expo/types/**/*.ts", "expo-env.d.ts", "nativewind-env.d.ts", "clerk-expo.d.ts", "API/**/*.js", "context/**/*.js" ]
}
